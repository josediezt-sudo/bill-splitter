# Anthropic API (required for OCR and email parsing)
ANTHROPIC_API_KEY=sk-ant-...your-key-here

# Google OAuth (required for Gmail sync)
GOOGLE_CLIENT_ID=your-client-id-from-google-cloud.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# For production (Railway), use:
# GOOGLE_REDIRECT_URI=https://web-production-xxxxx.up.railway.app/api/gmail/callback
